{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=SWDGradingDB;User Id=sa;Password=YourStr0ng!Pass;TrustServerCertificate=True;Encrypt=False;"
  },
  "JwtSettings": {
    "SecretKey": "key32",
    "Issuer": "SWD-Grading",
    "Audience": "SWD-Grading-Client",
    "ExpiryInMinutes": 60
  },
  "AWS": {
    "BucketName": "your-bucket-name",
    "Region": "ap-southeast-1",
    "AccessKey": "your-access-key",
    "SecretKey": "your-secret-key"
  },
  "FileUpload": {
    "MaxFileSizeMB": 500,
    "AllowedExtensions": [".zip", ".rar"],
    "TempStoragePath": "temp/uploads"
  },
  "Qdrant": {
    "Endpoint": "http://localhost:6334",
    "CollectionName": "exam_submissions",
    "VectorSize": "384"
  },
  "PacketSimilarity": {
    "DefaultThreshold": 0.8,
    "SameQuestionThreshold": 0.8,
    "GlobalThreshold": 0.9,
    "SeedTestDataOnStartup": false,
    "SeedExamId": null,
    "QuestionThresholds": [
      {
        "ExamId": 1,
        "QuestionNumber": 1,
        "Scope": "SameQuestion",
        "Threshold": 0.85
      },
      {
        "ExamId": 1,
        "QuestionNumber": null,
        "Scope": "Global",
        "Threshold": 0.92
      }
    ]
  }
}

